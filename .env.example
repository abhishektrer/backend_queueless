# ============================================
# QueueLess AI - Backend Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================
# JWT Authentication
# ============================================
# Generate a strong secret key (minimum 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d

# Admin Registration Code (change this for security!)
ADMIN_REGISTRATION_CODE=ADMIN2024

# ============================================
# MongoDB Atlas Configuration
# ============================================
# Get this from MongoDB Atlas: https://cloud.mongodb.com/
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/queueless_ai?retryWrites=true&w=majority

# ============================================
# Firebase Admin SDK Configuration
# ============================================
# Get these from Firebase Console > Project Settings > Service Accounts
# Download JSON and copy values here
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ============================================
# Groq AI API (For AI Features)
# ============================================
# Get API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Email Service (Resend)
# ============================================
# Get API key from: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# ============================================
# Push Notifications (OneSignal)
# ============================================
# Get these from: https://onesignal.com/
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# ============================================
# Frontend URL (CORS)
# ============================================
# Development
FRONTEND_URL=http://localhost:5173
# Production (update after deploying frontend)
# FRONTEND_URL=https://your-frontend-url.onrender.com
